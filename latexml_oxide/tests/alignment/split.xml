<?xml version="1.0" encoding="UTF-8"?>
<?latexml class="book" options="a4paper"?>
<?latexml package="amsmath"?>
<?latexml RelaxNGSchema="LaTeXML"?>
<document xmlns="http://dlmf.nist.gov/LaTeXML">
  <resource src="LaTeXML.css" type="text/css"/>
  <resource src="ltx-book.css" type="text/css"/>
  <para xml:id="p1">
    <p>Plain aligns</p>
  </para>
  <para xml:id="p2">
    <equationgroup class="ltx_eqn_align" xml:id="Ch0.S0.EGx1">
      <equation xml:id="Ch0.E1">
        <MathFork>
          <Math text="A = B" xml:id="Ch0.E1.m3">
            <XMath>
              <XMApp>
                <XMTok meaning="equals" role="RELOP">=</XMTok>
                <XMTok font="italic" role="UNKNOWN">A</XMTok>
                <XMTok font="italic" role="UNKNOWN">B</XMTok>
              </XMApp>
            </XMath>
          </Math>
          <MathBranch>
            <td align="right"><Math mode="inline" tex="\displaystyle A=" xml:id="Ch0.E1.m1">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">A</XMTok>
                  <XMTok meaning="equals" role="RELOP">=</XMTok>
                </XMath>
              </Math></td>
            <td align="left"><Math mode="inline" tex="\displaystyle B" text="B" xml:id="Ch0.E1.m2">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">B</XMTok>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
      <equation xml:id="Ch0.E2">
        <MathFork>
          <Math text="C = D" xml:id="Ch0.E2.m3">
            <XMath>
              <XMApp>
                <XMTok meaning="equals" role="RELOP">=</XMTok>
                <XMTok font="italic" role="UNKNOWN">C</XMTok>
                <XMTok font="italic" role="UNKNOWN">D</XMTok>
              </XMApp>
            </XMath>
          </Math>
          <MathBranch>
            <td align="right"><Math mode="inline" tex="\displaystyle C=" xml:id="Ch0.E2.m1">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">C</XMTok>
                  <XMTok meaning="equals" role="RELOP">=</XMTok>
                </XMath>
              </Math></td>
            <td align="left"><Math mode="inline" tex="\displaystyle D" text="D" xml:id="Ch0.E2.m2">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">D</XMTok>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
    </equationgroup>
  </para>
  <para xml:id="p3">
    <equationgroup class="ltx_eqn_align" xml:id="Ch0.S0.EGx2">
      <equation xml:id="Ch0.E4">
        <MathFork>
          <Math text="A = B" xml:id="Ch0.E4.m3">
            <XMath>
              <XMApp>
                <XMTok meaning="equals" role="RELOP">=</XMTok>
                <XMTok font="italic" role="UNKNOWN">A</XMTok>
                <XMTok font="italic" role="UNKNOWN">B</XMTok>
              </XMApp>
            </XMath>
          </Math>
          <MathBranch>
            <td align="right"><Math mode="inline" tex="\displaystyle A=" xml:id="Ch0.E4.m1">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">A</XMTok>
                  <XMTok meaning="equals" role="RELOP">=</XMTok>
                </XMath>
              </Math></td>
            <td align="left"><Math mode="inline" tex="\displaystyle B" text="B" xml:id="Ch0.E4.m2">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">B</XMTok>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
      <equation xml:id="Ch0.E5">
        <MathFork>
          <Math text="C = D" xml:id="Ch0.E5.m3">
            <XMath>
              <XMApp>
                <XMTok meaning="equals" role="RELOP">=</XMTok>
                <XMTok font="italic" role="UNKNOWN">C</XMTok>
                <XMTok font="italic" role="UNKNOWN">D</XMTok>
              </XMApp>
            </XMath>
          </Math>
          <MathBranch>
            <td align="right"><Math mode="inline" tex="\displaystyle C=" xml:id="Ch0.E5.m1">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">C</XMTok>
                  <XMTok meaning="equals" role="RELOP">=</XMTok>
                </XMath>
              </Math></td>
            <td align="left"><Math mode="inline" tex="\displaystyle D" text="D" xml:id="Ch0.E5.m2">
                <XMath>
                  <XMTok font="italic" role="UNKNOWN">D</XMTok>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
      <equation xml:id="Ch0.Ex1">
        <MathFork>
          <Math text="+ E" xml:id="Ch0.Ex1.m2">
            <XMath>
              <XMApp>
                <XMTok meaning="plus" role="ADDOP">+</XMTok>
                <XMTok font="italic" role="UNKNOWN">E</XMTok>
              </XMApp>
            </XMath>
          </Math>
          <MathBranch>
            <td/>
            <td align="left"><Math mode="inline" tex="\displaystyle+E" text="+ E" xml:id="Ch0.Ex1.m1">
                <XMath>
                  <XMApp>
                    <XMTok meaning="plus" role="ADDOP">+</XMTok>
                    <XMTok font="italic" role="UNKNOWN">E</XMTok>
                  </XMApp>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
    </equationgroup>
  </para>
  <para xml:id="p4">
    <p>Equations (<ref labelref="LABEL:eq:before"/>) and (<ref labelref="LABEL:eq:after"/>):</p>
    <equationgroup class="ltx_eqn_align" xml:id="Ch0.S0.EGx3">
      <equation xml:id="Ch0.E6">
        <MathFork>
          <Math text="list@(x, c _ 1)" xml:id="Ch0.E6.m2">
            <XMath>
              <XMDual>
                <XMRef idref="Ch0.E6.m2.3"/>
                <XMWrap>
                  <XMDual xml:id="Ch0.E6.m2.3">
                    <XMApp>
                      <XMTok meaning="list"/>
                      <XMRef idref="Ch0.E6.m2.1"/>
                      <XMRef idref="Ch0.E6.m2.2"/>
                    </XMApp>
                    <XMWrap>
                      <XMTok font="italic" role="UNKNOWN" xml:id="Ch0.E6.m2.1">x</XMTok>
                      <XMHint name="quad" role="PUNCT" width="10pt"/>
                      <XMApp xml:id="Ch0.E6.m2.2">
                        <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                        <XMTok font="italic" role="UNKNOWN">c</XMTok>
                        <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                      </XMApp>
                    </XMWrap>
                  </XMDual>
                  <XMTok role="PUNCT">,</XMTok>
                </XMWrap>
              </XMDual>
            </XMath>
          </Math>
          <MathBranch>
            <td/>
            <td align="left"><Math mode="inline" tex="\displaystyle x\quad c_{1}," text="list@(x, c _ 1)" xml:id="Ch0.E6.m1">
                <XMath>
                  <XMDual>
                    <XMRef idref="Ch0.E6.m1.3"/>
                    <XMWrap>
                      <XMDual xml:id="Ch0.E6.m1.3">
                        <XMApp>
                          <XMTok meaning="list"/>
                          <XMRef idref="Ch0.E6.m1.1"/>
                          <XMRef idref="Ch0.E6.m1.2"/>
                        </XMApp>
                        <XMWrap>
                          <XMTok font="italic" role="UNKNOWN" xml:id="Ch0.E6.m1.1">x</XMTok>
                          <XMHint name="quad" role="PUNCT" width="10pt"/>
                          <XMApp xml:id="Ch0.E6.m1.2">
                            <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                            <XMTok font="italic" role="UNKNOWN">c</XMTok>
                            <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                          </XMApp>
                        </XMWrap>
                      </XMDual>
                      <XMTok role="PUNCT">,</XMTok>
                    </XMWrap>
                  </XMDual>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
    </equationgroup>
    <p>and</p>
    <equationgroup class="ltx_eqn_align" xml:id="Ch0.S0.EGx4">
      <equation labels="LABEL:eq:after" xml:id="Ch0.E7">
        <MathFork>
          <Math text="list@(y, c _ 2)" xml:id="Ch0.E7.m2">
            <XMath>
              <XMDual>
                <XMRef idref="Ch0.E7.m2.3"/>
                <XMWrap>
                  <XMDual xml:id="Ch0.E7.m2.3">
                    <XMApp>
                      <XMTok meaning="list"/>
                      <XMRef idref="Ch0.E7.m2.1"/>
                      <XMRef idref="Ch0.E7.m2.2"/>
                    </XMApp>
                    <XMWrap>
                      <XMTok font="italic" role="UNKNOWN" xml:id="Ch0.E7.m2.1">y</XMTok>
                      <XMHint name="quad" role="PUNCT" width="10pt"/>
                      <XMApp xml:id="Ch0.E7.m2.2">
                        <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                        <XMTok font="italic" role="UNKNOWN">c</XMTok>
                        <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                      </XMApp>
                    </XMWrap>
                  </XMDual>
                  <XMTok role="PUNCT">,</XMTok>
                </XMWrap>
              </XMDual>
            </XMath>
          </Math>
          <MathBranch>
            <td/>
            <td align="left"><Math mode="inline" tex="\displaystyle y\quad c_{2}," text="list@(y, c _ 2)" xml:id="Ch0.E7.m1">
                <XMath>
                  <XMDual>
                    <XMRef idref="Ch0.E7.m1.3"/>
                    <XMWrap>
                      <XMDual xml:id="Ch0.E7.m1.3">
                        <XMApp>
                          <XMTok meaning="list"/>
                          <XMRef idref="Ch0.E7.m1.1"/>
                          <XMRef idref="Ch0.E7.m1.2"/>
                        </XMApp>
                        <XMWrap>
                          <XMTok font="italic" role="UNKNOWN" xml:id="Ch0.E7.m1.1">y</XMTok>
                          <XMHint name="quad" role="PUNCT" width="10pt"/>
                          <XMApp xml:id="Ch0.E7.m1.2">
                            <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                            <XMTok font="italic" role="UNKNOWN">c</XMTok>
                            <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                          </XMApp>
                        </XMWrap>
                      </XMDual>
                      <XMTok role="PUNCT">,</XMTok>
                    </XMWrap>
                  </XMDual>
                </XMath>
              </Math></td>
          </MathBranch>
        </MathFork>
      </equation>
    </equationgroup>
  </para>
  <para xml:id="p5">
    <p>Aligned within math</p>
    <equation xml:id="Ch0.Ex2">
      <Math mode="display" tex="\begin{aligned} A=&amp;B\end{aligned}" text="Array[[A=, B]]" xml:id="Ch0.Ex2.m1">
        <XMath>
          <XMArray>
            <XMRow>
              <XMCell align="right">
                <XMArg rule="Anything">
                  <XMTok font="italic" role="UNKNOWN">A</XMTok>
                  <XMTok meaning="equals" role="RELOP">=</XMTok>
                </XMArg>
              </XMCell>
              <XMCell align="left">
                <XMTok font="italic" role="UNKNOWN">B</XMTok>
              </XMCell>
            </XMRow>
          </XMArray>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p6">
    <p>Tendency to see the ampersand before aligned has started</p>
    <equation xml:id="Ch0.Ex3">
      <Math mode="display" tex="C=\left\{\begin{aligned} &amp;D\end{aligned}\right\right." xml:id="Ch0.Ex3.m1">
        <XMath>
          <XMTok font="italic" role="UNKNOWN">C</XMTok>
          <XMTok meaning="equals" role="RELOP">=</XMTok>
          <XMTok role="OPEN" stretchy="true">{</XMTok>
          <XMArray>
            <XMRow>
              <XMCell/>
              <XMCell align="left">
                <XMTok font="italic" role="UNKNOWN">D</XMTok>
              </XMCell>
            </XMRow>
          </XMArray>
        </XMath>
      </Math>
    </equation>
  </para>
  <para xml:id="p7">
    <p>Align with aligned
</p>
  </para>
</document>
