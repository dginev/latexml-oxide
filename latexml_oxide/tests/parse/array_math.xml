          <XMWrap>
            <XMTok role="OPEN" stretchy="true">{</XMTok>
            <XMArray>
              <XMRow>
                <XMCell align="left">
                  <XMTok font="italic" role="ID">d</XMTok>
                </XMCell>
                <XMCell align="left">
                  <XMTok font="italic" role="ID">c</XMTok>
                </XMCell>
