  <para xml:id="p1">
    <equation xml:id="S0.Ex1">
      <Math mode="display" tex="\nabla^{2}\phi=0" text="(nabla ^ 2)@(phi) = 0" xml:id="S0.Ex1.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="equals" role="RELOP">=</XMTok>
            <XMApp>
              <XMApp role="OPERATOR">
                <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
                <XMTok name="nabla" role="OPERATOR">∇</XMTok>
                <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
              <XMTok font="italic" name="phi" role="UNKNOWN">ϕ</XMTok>
            </XMApp>
            <XMTok meaning="0" role="NUMBER">0</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
    <equation xml:id="S0.Ex2">
      <Math mode="display" tex="\nabla_{x}f" text="(nabla _ x)@(f)" xml:id="S0.Ex2.m1">
