<?xml version="1.0" encoding="UTF-8"?>
<?latexml class="article"?>
<?latexml package="amssymb,amsmath"?>
<?latexml RelaxNGSchema="LaTeXML"?>
<document xmlns="http://dlmf.nist.gov/LaTeXML">
  <resource src="LaTeXML.css" type="text/css"/>
  <resource src="ltx-article.css" type="text/css"/>
  <para xml:id="p1">
    <equation xml:id="S0.Ex1">
      <Math mode="display" tex="\nabla\phi" text="nabla@(phi)" xml:id="S0.Ex1.m1">
        <XMath>
          <XMApp>
            <XMTok name="nabla" role="OPERATOR">∇</XMTok>
            <XMTok font="italic" name="phi" role="UNKNOWN">ϕ</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
    <equation xml:id="S0.Ex2">
      <Math mode="display" tex="\partial f" text="partial-differential@(f)" xml:id="S0.Ex2.m1">
        <XMath>
          <XMApp>
            <XMTok meaning="partial-differential" name="partial" role="DIFFOP">∂</XMTok>
            <XMTok font="italic" role="UNKNOWN">f</XMTok>
          </XMApp>
        </XMath>
      </Math>
    </equation>
    <equation xml:id="S0.Ex3">
      <Math mode="display" tex="\sum_{i=1}^{n}a_{i}" text="((sum _ (i = 1)) ^ n)@(a _ i)" xml:id="S0.Ex3.m1">
        <XMath>
          <XMApp>
            <XMApp>
              <XMTok role="SUPERSCRIPTOP" scriptpos="mid1"/>
              <XMApp>
                <XMTok role="SUBSCRIPTOP" scriptpos="mid1"/>
                <XMTok mathstyle="display" meaning="sum" role="SUMOP" scriptpos="mid">∑</XMTok>
                <XMApp>
                  <XMTok fontsize="70%" meaning="equals" role="RELOP">=</XMTok>
                  <XMTok font="italic" fontsize="70%" role="UNKNOWN">i</XMTok>
                  <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                </XMApp>
              </XMApp>
              <XMTok font="italic" fontsize="70%" role="UNKNOWN">n</XMTok>
            </XMApp>
            <XMApp>
              <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
              <XMTok font="italic" role="UNKNOWN">a</XMTok>
              <XMTok font="italic" fontsize="70%" role="UNKNOWN">i</XMTok>
            </XMApp>
          </XMApp>
        </XMath>
      </Math>
    </equation>
    <equation xml:id="S0.Ex4">
      <Math mode="display" tex="\int_{0}^{1}g\,dx" text="((integral _ 0) ^ 1)@(g * differential-d@(x))" xml:id="S0.Ex4.m1">
        <XMath>
          <XMApp>
            <XMApp>
              <XMTok role="SUPERSCRIPTOP" scriptpos="post1"/>
              <XMApp>
                <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                <XMTok mathstyle="display" meaning="integral" name="int" role="INTOP">∫</XMTok>
                <XMTok fontsize="70%" meaning="0" role="NUMBER">0</XMTok>
              </XMApp>
              <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
            </XMApp>
            <XMApp>
              <XMTok meaning="times" role="MULOP">⁢</XMTok>
              <XMTok font="italic" role="UNKNOWN" rpadding="1.7pt">g</XMTok>
              <XMApp>
                <XMTok font="italic" meaning="differential-d" role="DIFFOP">d</XMTok>
                <XMTok font="italic" role="UNKNOWN">x</XMTok>
              </XMApp>
            </XMApp>
          </XMApp>
        </XMath>
      </Math>
    </equation>
    <equation xml:id="S0.Ex5">
      <Math mode="display" tex="\sin(x)" text="sine@(x)" xml:id="S0.Ex5.m1">
        <XMath>
          <XMDual>
            <XMApp>
              <XMRef idref="S0.Ex5.m1.1"/>
              <XMRef idref="S0.Ex5.m1.2"/>
            </XMApp>
            <XMApp>
              <XMTok meaning="sine" role="TRIGFUNCTION" xml:id="S0.Ex5.m1.1">sin</XMTok>
              <XMWrap>
                <XMTok role="OPEN" stretchy="false">(</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S0.Ex5.m1.2">x</XMTok>
                <XMTok role="CLOSE" stretchy="false">)</XMTok>
              </XMWrap>
            </XMApp>
          </XMDual>
        </XMath>
      </Math>
    </equation>
  </para>
</document>
