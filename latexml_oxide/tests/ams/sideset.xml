  <paragraph inlist="toc" xml:id="S0.SS0.SSS0.Px1">
    <title>Sideset</title>
    <para xml:id="S0.SS0.SSS0.Px1.p1">
      <equation xml:id="S0.Ex1">
        <Math mode="display" tex="\sideset{}{{}^{\prime}}\sum_{i=1}^{\infty}S_{i}" xml:id="S0.Ex1.m1">
