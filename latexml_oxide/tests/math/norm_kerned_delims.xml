    <title><tag close=" ">1</tag>Single-bar absolute value: parses OK</title>
    <para xml:id="S1.p1">
      <equation xml:id="S1.Ex1">
        <Math mode="display" tex="{\left|x\right|}={\left|-x\right|}" text="absolute-value@(x) = absolute-value@(- x)" xml:id="S1.Ex1.m1">
