            </XMDual>
          </XMath>
        </Math>
      </equation>
      <equation xml:id="S2.Ex5">
        <Math mode="display" tex="g,g(a),g(a)(b)" text="list@(g, g * a, g * a * b)" xml:id="S2.Ex5.m1">
