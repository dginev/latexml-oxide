                  <XMTok role="SUBSCRIPTOP" scriptpos="post1"/>
                  <XMTok font="italic" role="ID">x</XMTok>
                  <XMTok font="italic" fontsize="70%" role="ID">n</XMTok>
                </XMApp>
                <XMTok role="PUNCT">,</XMTok>
                <XMApp xml:id="S1.Ex1.m1.8">
