    <para xml:id="S4.p1">
      <equation xml:id="S4.Ex8">
        <Math mode="display" tex="a,b,c,ab,bc,abc" text="list@(a, b, c, a * b, b * c, a * b * c)" xml:id="S4.Ex8.m1">
