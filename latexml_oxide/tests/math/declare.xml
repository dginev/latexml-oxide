            <XMDual>
              <XMApp>
                <XMTok meaning="list"/>
                <XMRef idref="S4.Ex8.m1.1"/>
                <XMRef idref="S4.Ex8.m1.2"/>
                <XMRef idref="S4.Ex8.m1.3"/>
                <XMRef idref="S4.Ex8.m1.4"/>
                <XMRef idref="S4.Ex8.m1.5"/>
                <XMRef idref="S4.Ex8.m1.6"/>
              </XMApp>
              <XMWrap>
                <XMTok font="italic" role="UNKNOWN" xml:id="S4.Ex8.m1.1">a</XMTok>
                <XMTok role="PUNCT">,</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S4.Ex8.m1.2">b</XMTok>
                <XMTok role="PUNCT">,</XMTok>
                <XMTok font="italic" role="UNKNOWN" xml:id="S4.Ex8.m1.3">c</XMTok>
                <XMTok role="PUNCT">,</XMTok>
                <XMApp xml:id="S4.Ex8.m1.4">
                  <XMTok meaning="times" role="MULOP">⁢</XMTok>
                  <XMTok font="italic" role="UNKNOWN">a</XMTok>
                  <XMTok font="italic" role="UNKNOWN">b</XMTok>
