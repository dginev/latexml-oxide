    <para xml:id="S2.p1">
      <equation xml:id="S2.Ex3">
        <Math mode="display" tex="q,q_{a},q_{a,b},\mbox{ but accidentally }q_{a+b}" text="list@(q, q _ a, q _ (list@([], [])), [ but accidentally ] * q _ (a + b))" xml:id="S2.Ex3.m1">
