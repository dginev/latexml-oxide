    <title><tag close=" ">1</tag>Basics</title>
    <para xml:id="S1.p1">
      <equation xml:id="S1.Ex1">
        <Math mode="display" tex="x,x^{\prime},x_{1},x_{n},x_{2n-1},\hat{x},\widehat{x},\mathbf{x}" text="list@(x, x ^ prime, x _ 1, x _ n, x _ (2 * n - 1), hat@(x), widehat@(x), x)" xml:id="S1.Ex1.m1">
