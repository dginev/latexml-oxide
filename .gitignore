# Compiled files
*.o
*.so
*.rlib
*.dll

# Executables
*.exe

# Generated by Cargo
/target/
*target/
*.lock
*.bk

# Rls auxiliaries
rls/*

# VSCode
*.code-workspace

# Profiling
*.dot
profs/*

# Auto-generated kernel dumps (created by build.rs / --init)
latexml_package/src/engine/*_dump.rs

# Post-processing test actual output
*-post-actual.xml

# Kernel dumps: versioned files (plain.YYYY.dump.txt etc.) are committed
# so the binary can find them at runtime / embed them at build time.
# Local-only un-versioned variants and other debris in this dir stay
# ignored.
resources/dumps/*
!resources/dumps/plain.*.dump.txt
!resources/dumps/latex.*.dump.txt
!resources/dumps/texlive.*.version

# Local-dev scratch: arxiv-examples conversion fixtures, sandbox
# conversion logs, ad-hoc notes. None belong in the repo.
arxiv-examples/
*.latexml.log
USER_OK.md

# Local Claude Code settings and ad-hoc HTML conversion outputs
.claude/
html/

# Python bytecode (e.g. tools/check_memory.py emits __pycache__/)
__pycache__/
*.pyc

# Reference / read-only mirror trees (Perl LaTeXML upstream sources,
# community ar5iv-bindings .ltxml, TeXbook + tex.web). These live
# alongside the repo for cross-reference during the Perl→Rust port
# but are never modified or compiled. Per CLAUDE.md, LaTeXML/ is
# the ground-truth reference and must not be edited.
# `LaTeXML` here matches both a symlink and a real directory; the
# trailing-slash form on the others stays since they're true dirs.
LaTeXML
ar5iv-bindings/
background/
.session_state/
