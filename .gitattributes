# Kernel dumps are generated by `tools/make_formats.sh` and check in at
# ~7 MB / ~110k lines each. Mark them as generated so:
#   - GitHub language stats don't count them toward repo composition
#   - `git diff` skips the inline diff (the byte-level info is rarely useful)
#   - `git log --follow` doesn't try to track per-line history
resources/dumps/*.dump.txt -diff -merge linguist-generated
resources/dumps/texlive.*.version       linguist-generated
